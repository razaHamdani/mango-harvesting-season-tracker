# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is gitignored.

# ── Supabase ────────────────────────────────────────────────────────────────
# Local dev: run `npx supabase start` and copy the values from its output.
# Production: get these from your Supabase project dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Upstash Redis — rate limiting ───────────────────────────────────────────
# Required before deploying to production.
# 1. Create a Redis database at https://console.upstash.com
# 2. Open the database → REST API tab
# 3. Copy the URL and token below.
#
# If these are blank, rate limiting is disabled (app still runs, not safe for prod).
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Production domain (Server Actions CSRF allowlist) ───────────────────────
# Set to your deployed domain (e.g. "aamdaata.example.com") so Server Actions
# accept requests from this origin even when behind a proxy that rewrites Host.
# Leave unset in local dev — same-origin protection applies by default.
NEXT_PUBLIC_PROD_DOMAIN=

# ── Sentry (error monitoring) ───────────────────────────────────────────────
# Get these from https://sentry.io → your project → Settings → Client Keys (DSN)
# When unset, Sentry SDK is a no-op (no errors uploaded).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Auth token + org/project required only for sourcemap uploads at build time.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
